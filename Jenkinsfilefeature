pipeline {
    agent any

    triggers {
        pollSCM('H/2 * * * *')
    }

    environment {
        APP_DIR = "/var/www/myapp"
    }


    stages {

        stage('Checkout') {
            steps {
                git url: 'https://github.com/mahalakshmi191/my-app.git', branch: 'main'
            }
        }

        stage('Build') {
            steps {
                bat 'npm install'
            }
        }

        stage('Test') {
            steps {
                bat 'npm test || true'
            }
        }

        stage('Deploy to STAGING') {
            when {
                branch pattern: "release/.*", comparator: "REGEXP"
            }
            steps {
                sh '''
                ssh user@staging-server "
                  cd $APP_DIR &&
                  git pull &&
                  npm install &&
                  pm2 restart app
                "
                '''
            }
        }

        stage('Deploy to PROD') {
            when {
                branch 'main'
            }
            steps {
                input message: "Approve Production Deployment?"
                sh '''
                ssh user@prod-server "
                  cd $APP_DIR &&
                  git pull origin main &&
                  npm install &&
                  pm2 restart app
                "
                '''
            }
        }
    }
}
